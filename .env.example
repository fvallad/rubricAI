# Docker Project Name
COMPOSE_PROJECT_NAME=rubricai
COMPOSE_FILE=docker-compose.yml

# Moodle Configuration
MOODLE_VERSION=MOODLE_405_STABLE
MOODLE_URL=http://localhost:8080
MOODLE_DATA_ROOT=/var/www/moodledata

# Database Configuration
DB_TYPE=pgsql
DB_HOST=db
DB_NAME=moodle
DB_USER=dbuser
DB_PASS=password
DB_PORT=5432

# Moodle Admin Configuration (First time install)
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASS=password
MOODLE_ADMIN_EMAIL=email@example.com
MOODLE_FULLNAME=RubricAI Moodle
MOODLE_SHORTNAME=RubricAI


# Python path (por seguridad, es mejor idea separar en 2 envs)
# RUBRICAI_SYNC_PATH=/var/www/moodledata/rubricai_sync
RUBRICAI_SYNC_PATH=./data/sync
# NOTE: Use host.docker.internal to reach the Python service on your host from Moodle container.
RUBRICAI_AI_URL=http://localhost:8000


# LLM Provider Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# Neo4j Database Configuration (Aura Cloud — credenciales desde aura.neo4j.io)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEO4J_DATABASE=neo4j
AURA_INSTANCEID=xxxxxxxx
AURA_INSTANCENAME=Instance01

# LangSmith Tracing (obtené tu API key en https://smith.langchain.com)
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=rubricai_dev

# Activar trazabilidad: true | false
LANGSMITH_TRACING=true
LANGSMITH_TRACING_V2=true
LANGCHAIN_CALLBACKS_BACKGROUND=true
LANGCHAIN_VERBOSE=true
