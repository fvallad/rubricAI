.env
*.pyc
**/__pycache__/

# Python virtual environments (5.6 GB - MUST BE EXCLUDED)
rubricai_ai/.venv/
venv/
.venv/

# Node modules (140 MB - MUST BE EXCLUDED)
**/node_modules/

# AI local search indexes (31 MB - EXCLUDE)
rubricai_ai/data/

# Moodle data directory:
# We EXCLUDE caches, sessions, secrets, temp files, and large backups, but ALLOW filedir (images) and structure
moodledata/cache/
moodledata/localcache/
moodledata/sessions/
moodledata/temp/
moodledata/trashdir/
moodledata/muc/
moodledata/secret/
moodledata/backups/*.mbz
moodledata/backups/*.zip

# ZIP files (except packaging if any, but we ignore general zips)
rubricai_plugin.zip