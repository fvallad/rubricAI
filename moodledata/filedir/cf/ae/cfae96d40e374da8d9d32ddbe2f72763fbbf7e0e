/* === TIPOGRAFÍA GLOBAL === */
.bloque-interactivo h1,
.bloque-interactivo h2,
.bloque-interactivo h3,
.bloque-interactivo h4,
.bloque-interactivo h5,
.bloque-interactivo h6,
.bloque-interactivo p,
.bloque-interactivo span,
.bloque-interactivo a,
.bloque-interactivo li,
.bloque-interactivo dt,
.bloque-interactivo dd,
.bloque-interactivo blockquote,
.bloque-interactivo strong,
.bloque-interactivo em,
.bloque-interactivo label,
.bloque-interactivo th,
.bloque-interactivo table
.bloque-interactivo td {
  font-family: 'Poppins', sans-serif !important;
}

/* === BLOQUE GENERAL === */
.bloque-interactivo {
  background-color: #ffffff;
  border: 1px solid #ddd;
  width: 100%;
  max-width: 100%;
}

/* === ENCABEZADO === */
.encabezado {
  background-color: #fff;
  text-align: center;
}

.encabezado img {
  width: 100%;
  height: auto;
  display: block;
}

.titulo-con-icono {
  background-color: var(--color-principal);
  color: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 40px;
}

.titulo-con-icono h1 {
  font-size: 1.5em;
  margin: 0;
  color: white;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  font-family: 'Poppins', sans-serif;
}

/* === ENLACE CON ICONO === */
.icono-link {
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  padding-left: 10px;
}

.icono-link svg {
  width: 24px;
  height: 24px;
  fill: white;
}

/* === PRESENTACIÓN DEL MÓDULO === */
.presentacion-modulo {
  background-color: #ffffff;
  padding: 25px 10px 20px 10px;
  text-align: left;
}

.texto-presentacion {
  max-width: 1100px;
  margin: 0 auto;
  color: #333;
  font-size: 1em;
  line-height: 1.6;
  font-family: 'Poppins', sans-serif;
  font-weight: 300;
}

/* Línea separadora */
.linea-fina {
  border: none;
  height: 1px;
  background-color: #cccc;
  margin: 2px auto 20px auto;
  width: 93%;
}

/* Tabla tipo definición con línea solo en columna derecha */

.tabla-flex {
  display: flex;
  flex-direction: column;
  gap: 24px;
  font-family: 'Poppins', sans-serif;
  padding: 20px;
}

.fila {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
}

.columna-titulo {
  flex: 1 1 20%;
  font-weight: 450;
  font-size: 1.2em;
  color: #333;
  min-width: 160px;
  font-family: 'Poppins', sans-serif;
}

.columna-contenido {
  flex: 1 1 75%;
  font-weight: 300;
  font-size: 1em;
  color: #333;
  border-top: 2px solid var(--color-principal);
  padding-top: 12px;
  font-family: 'Poppins', sans-serif;
}

.columna-contenido p {
  margin: 0;
}


/* === CONTENEDORES PRINCIPALES === */
#menu-container {
  display: flex;
  flex-wrap: nowrap;
  width: 100%;
}

/* === MENÚ LATERAL === */
#sidebar {
  width: 220px;
  flex-shrink: 0;
  background-color: white;
  padding: 20px 4px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.item-menu {
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  padding: 8px;
  border-radius: 8px;
  transition: background-color 0.2s ease;
  background-color: transparent;
  box-shadow: 3px 0 6px rgba(0, 0, 0, 0.1); /*Ver si queda*/
  flex-direction: row;
}

.item-menu img.icono-menu {
  width: 50px;
  height: 50px;
  border-radius: 12px;
  box-shadow: none;
  transition: none;
}

.item-menu span {
  font-family: 'Poppins', sans-serif;
  font-weight: 300;
  font-size: 12px;
  color: #333;
  word-break: break-word;
  white-space: normal;
  max-width: 140px;
  text-align: center;
  transition: color 0.2s ease;
}

/* Hover y activo */
.item-menu:hover {
  background-color: var(--color-hover);
}

.item-menu:hover img.icono-menu {
  content: url('https://campus.citep.rec.uba.ar/repository/coursefilearea/file.php/1/estudiodecasos/hoverlila.png');
}

.item-menu:hover span {
  color: white;
}

.item-menu.activo {
  background-color: var(--color-principal);
}

.item-menu.activo img.icono-menu {
  content: url('https://campus.citep.rec.uba.ar/repository/coursefilearea/file.php/1/estudiodecasos/hoveroscuro.png');
}

.item-menu.activo span {
  color: white;
}

/* === CONTENIDO PRINCIPAL === */
#contenido-principal {
  flex-grow: 1;
  min-width: 0;
  padding: 20px;
  background-color: #ffffff;
}

.contenido {
  display: none;
}

.visible {
  display: block;
}

/* === SUBTÍTULOS === */
.subtitulo {
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  font-size: 17pt;
  line-height: 42px;
  color: var(--color-subtitulo);
  margin-bottom: -2px;
  background-color: transparent;
  display: inline-block;
  border-radius: 0;
  text-transform: none;
  letter-spacing: 0.5px;
  margin-top: -8px;
}

/* === CUERPO DE TEXTO === */
.cuerpo-texto {
  font-family: 'Poppins', sans-serif;
  font-weight: 300;
  line-height: 1.6;
  color: #333;
  max-width: 800px;
}

.cuerpo-texto p {
  margin-bottom: 1em;
  text-align: justify;
}

.dos-columnas {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
}

.dos-columnas p {
  flex: 1 1 45%;
  min-width: 250px;
}

/* === PIE DE PÁGINA === */
footer.pie {
  background-color: #e3e4e5;
  text-align: center;
  padding: 40px 20px 20px;
  border-top: 1px solid #ccc;
}

.btn-descarga {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background-color: var(--color-principal);
  color: white;
  text-decoration: none;
  padding: 10px 20px;
  border-radius: 20px;
  font-weight: 500;
  transition: background-color 0.2s ease, color 0.2s ease;
}

/* === CENTRADO OPCIONAL PARA BOTONES === */
.btn-centrado {
  display: inline-flex;
  justify-content: center;
  text-align: center;
  margin: 20px auto 0;
  max-width: 100%;
}

/*hover y activo del botón de descarga*/
.btn-descarga:hover {
  color: var(--color-boton-texto-hover);
}

.btn-descarga:active {
  background-color: var(--color-principal);
  color: white;
  outline: none;
  box-shadow: none;
}

.btn-descarga img {
  width: 24px;
  height: 24px;
}

/* === POPUPS === */
.popup-trigger {
  cursor: pointer;
  color: var(--color-popup);
  font-weight: bold;
  text-decoration: underline dotted;
  position: relative;
}

